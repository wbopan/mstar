AZURE_OPENAI_API_VERSION="2025-03-01-preview"

# Primary Azure OpenAI pool used by agent runs, simulator, and inline scoring.
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"
AZURE_OPENAI_DEPLOYMENTS="gpt-5.1"

# Optional additional pooled endpoints. The client auto-discovers numbered pairs.
# AZURE_OPENAI_ENDPOINT_2="https://your-second-resource.openai.azure.com"
# AZURE_OPENAI_DEPLOYMENTS_2="gpt-5.1"

# Optional static token. If omitted, the client uses Azure CLI or DefaultAzureCredential.
# AZURE_OPENAI_TOKEN=""

# Notes:
# - The current benchmark harness does not use separate JUDGE env vars.
# - Embedding pricing is configured in configs/pricing.yaml, but there is no shared
#   embedding env var contract in the harness yet; custom agents own that integration.

# Azure AI Foundry examples for external memory systems or custom agents.
# AZURE_FOUNDRY_ENDPOINT="https://your-endpoint.services.ai.azure.com/api/projects/your-project"
# AZURE_FOUNDRY_DEPLOYMENTS="gpt-5.1"

# Google Memory
# GCLOUD_PROJECT_ID="your-project-id"
# GCLOUD_LOCATION="us-central1"

# AWS Memory
# AWS_REGION="us-west-2"
# AWS_MEMORY_NAME="StandaloneMemory"
# AWS_ACCESS_KEY_ID="your-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret-access-key"
